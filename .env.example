# Example environment variables for local development.
# Copy this file to .env.local and replace placeholder values.

# Server
PORT=8066
HOSTNAME=0.0.0.0
AUTH_SECRET=change-this-to-a-long-random-value

# Admin
ADMIN_EMAILS=admin@example.com
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-this-admin-password

# Plans and limits
PRO_PLAN_PRICE_USD=5
TEMP_RECEIVER_REQUEST_LIMIT=10000
TEMP_RECEIVER_RATE_LIMIT_PER_MINUTE=60
LOGGED_IN_RECEIVER_REQUEST_LIMIT=50000
LOGGED_IN_RECEIVER_RATE_LIMIT_PER_MINUTE=120
PRO_RECEIVER_REQUEST_LIMIT=1000000
PRO_RECEIVER_RATE_LIMIT_PER_MINUTE=1200
TEMP_USER_TTL_SECONDS=90

# Data Collection
MONGODB_URI=mongodb+srv://user:password@cluster.example.net/checkhooks
MONGODB_DB=checkhooks

# Cache Storage
REDIS_URL=redis://default:password@host:6379

# Razorpay checkout
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_CURRENCY=USD
RAZORPAY_PRO_AMOUNT_SUBUNITS=500
NEXT_PUBLIC_RAZORPAY_PRO_AMOUNT_SUBUNITS=500
